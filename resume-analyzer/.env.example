# Never commit .env to version control

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/resume_ai
DB_USERNAME=postgres
DB_PASSWORD=your_strong_db_password_here

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your_minimum_32_character_jwt_secret_here
JWT_EXPIRATION_MS=86400000

# RapidAPI — get from rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here
OPENWEBNINJA_KEY=your_openwebninja_key_here

# Python AI service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=your_shared_secret_here_min_32_chars

# File uploads
UPLOAD_DIR=./uploads

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173